# CDI Pipeline Configuration
# Copy this file to .env and update paths for your local environment.
# All paths are relative to the project root (cdi_analysis/) unless absolute.

# FTP Base URLs
MONTHLY_BASE_URL=https://droughtwatch.icpac.net/ftp/monthly/geotif/
DEKADAL_BASE_URL=https://droughtwatch.icpac.net/ftp/dekadal/geotif/

# Directories (defaults work out of the box — override only if needed)
# CDI_INPUT_DIR=cdi_input
# CDI_OUTPUT_DIR=cdi_output
# CDI_MONTHLY_DIR=cdi_monthly
# CDI_DEKADAL_DIR=cdi_dekadal

# Shapefiles (defaults resolve from CDI_INPUT_DIR)
# REGION_SHAPEFILE=cdi_input/icpac_countries_merged.shp
# WATERBODY_SHAPEFILE=cdi_input/water_bodies.shp

# Logo
# ICPAC_LOGO_PATH=assets/ICPAC_LOGO.png
